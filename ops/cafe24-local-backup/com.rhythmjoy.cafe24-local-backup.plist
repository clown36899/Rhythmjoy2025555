<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.rhythmjoy.cafe24-local-backup</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/inteyeo/Rhythmjoy2025555-5/scripts/backup-cafe24-to-local.sh</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>CAFE24_LOCAL_BACKUP_ROOT</key>
