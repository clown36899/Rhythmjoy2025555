{
  "manifest_version": 3,
  "name": "댄스빌보드 SNS 클리퍼",
  "version": "0.1.0",
  "description": "현재 YouTube, Instagram 페이지를 댄스빌보드 SNS 아카이브에 저장합니다.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "댄스빌보드에 저장"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ]
}
